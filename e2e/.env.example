WALLET_PASSWORD=
RECOVERY_PHRASE_12_WORDS=
RECOVERY_PHRASE_24_WORDS=

# Account Management import flows
# Raw private key imported by the "Import a private key" account-management test.
PRIVATE_KEY_IMPORT=
# Private key of the mainnet primary wallet account (triggers the duplicate
# "This account has already been imported" confirmation screen).
PRIVATE_KEY_MAIN_EXT_WALLET=
# X/P-Chain private key of the mainnet primary wallet (imports an account whose
# X/P-Chain address is avax1hypjnfr5fzqlpj5jrh2gqex2arujfl2lk9n9r5).
XP_PRIVATE_KEY_MAIN_EXT_WALLET=
# Passwords for the keystore JSON files stored in S3 under
# s3://core-qa-automation-snapshots/ext/keystores/ (synced to helpers/keystores).
#   keystore-v4.json            -> PASSWORD_KEYSTORE_V4
#   keystore-v6-private-key.json -> PASSWORD_KEYSTORE_V6
PASSWORD_KEYSTORE_V4=
PASSWORD_KEYSTORE_V6=

# Explorer API keys (used for on-chain tx verification in e2e)
APITOKEN_CRYPTOAPIS=
APITOKEN_ETHERSCAN=
# Glacier Data API (P/X primary + C-Chain EVM indexer when set; see developers.avacloud.io)
APITOKEN_GLACIER=

# TestRail automation sync (used by `yarn testrail:report` / `yarn testrail:sync`).
# API key is generated under TestRail > My Settings > API Keys (NOT your password).
TESTRAIL_HOST=https://avalabs.testrail.io
TESTRAIL_EMAIL=
TESTRAIL_API_KEY=
TESTRAIL_PROJECT_ID=
# Optional — restrict the sync to a single suite when the project has many.
TESTRAIL_SUITE_ID=
