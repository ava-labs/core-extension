WALLET_PASSWORD=
RECOVERY_PHRASE_12_WORDS=
RECOVERY_PHRASE_24_WORDS=

# Explorer API keys (used for on-chain tx verification in e2e)
APITOKEN_CRYPTOAPIS=
APITOKEN_ETHERSCAN=
# Glacier Data API (P/X primary + C-Chain EVM indexer when set; see developers.avacloud.io)
APITOKEN_GLACIER=

# TestRail automation sync (used by `yarn testrail:report` / `yarn testrail:sync`).
# API key is generated under TestRail > My Settings > API Keys (NOT your password).
TESTRAIL_HOST=https://avalabs.testrail.io
TESTRAIL_EMAIL=
TESTRAIL_API_KEY=
TESTRAIL_PROJECT_ID=
# Optional — restrict the sync to a single suite when the project has many.
TESTRAIL_SUITE_ID=
