{
  "name": "@core/lavamoat-rspack",
  "version": "0.0.1",
  "description": "LavaMoat Rspack plugin for running dependencies in Compartments without eval",
  "main": "src/plugin.js",
  "types": "types/plugin.d.ts",
  "exports": {
    ".": {
      "types": "./types/plugin.d.ts",
      "default": "./src/plugin.js"
    },
    "./rspack-nmf-generator-polyfill": {
      "default": "./src/rspackNmfGeneratorHookPolyfillPlugin.js"
    }
  },
  "files": [
    "src",
    "types"
  ],
  "keywords": [
    "rspack",
    "bundle",
    "security",
    "ses",
    "compartment",
    "sandbox",
    "hardened"
  ],
  "peerDependencies": {
    "@rspack/core": "^1.3.0"
  },
  "dependencies": {
    "@lavamoat/aa": "^5.0.0",
    "@lavamoat/types": "^1.0.0",
    "browser-resolve": "2.0.0",
    "lavamoat-core": "^18.0.0",
    "ses": "1.15.0"
  },
  "devDependencies": {
    "@types/browser-resolve": "2.0.5"
  }
}
